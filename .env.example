# Required: your FPL team ID (find at fantasy.premierleague.com/entry/{ID}/event/1)
FPL_ID=1234567

# Optional: comma-separated classic league IDs to auto-subscribe
# Find league IDs at fantasy.premierleague.com/leagues/{ID}/standings/c
FPL_LEAGUE_IDS=620795,929561

# Optional: enables betting odds data (free, 500 credits/month)
# Sign up at https://the-odds-api.com
FPL_ODDS_API_KEY=

# Optional: auto-refresh during match windows (Sat/Sun/Mon)
FPL_AUTO_REFRESH=true

# Optional: SQLite database path
FPL_DB_PATH=data/fpl.db
